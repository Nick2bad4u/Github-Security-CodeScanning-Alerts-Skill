{
    "[python]": {
        "editor.codeActionsOnSave": {
            "source.fixAll.ruff": "explicit",
            "source.organizeImports.ruff": "explicit"
        },
        "editor.defaultFormatter": "charliermarsh.ruff",
        "editor.formatOnSave": true
    },
    "mypy-type-checker.reportingScope": "workspace",
    "python-envs.defaultEnvManager": "ms-python.python:venv",
    "python.analysis.autoFormatStrings": true,
    "python.analysis.autoImportCompletions": true,
    "python.analysis.autoIndent": true,
    "python.analysis.autoSearchPaths": true,
    "python.analysis.autoSplitStrings": true,
    "python.analysis.completeFunctionParens": true,
    "python.analysis.diagnosticMode": "workspace",
    "python.analysis.enableColorPicker": true,
    "python.analysis.enableParallelIndexing": true,
    "python.analysis.enablePytestSupport": true,
    "python.analysis.enableTroubleshootMissingImports": true,
    "python.analysis.extraPaths": ["${workspaceFolder}/scripts"],
    "python.analysis.generateWithTypeAnnotation": true,
    "python.analysis.includeAliasesFromUserFiles": false,
    "python.analysis.indexing": true,
    "python.analysis.inlayHints.callArgumentNames": "all",
    "python.analysis.inlayHints.functionReturnTypes": true,
    "python.analysis.inlayHints.variableTypes": true,
    "python.analysis.persistAllIndices": true,
    "python.analysis.referencesCodeLens": true,
    "python.analysis.supportRestructuredText": true,
    "python.analysis.typeCheckingMode": "strict",
    "python.analysis.typeEvaluation.analyzeUnannotatedFunctions": true,
    "python.analysis.typeEvaluation.deprecateTypingAliases": true,
    "python.analysis.typeEvaluation.disableBytesTypePromotions": true,
    "python.analysis.typeEvaluation.enableReachabilityAnalysis": true,
    "python.analysis.typeEvaluation.enableTypeIgnoreComments": true,
    "python.analysis.typeEvaluation.strictDictionaryInference": true,
    "python.analysis.typeEvaluation.strictListInference": true,
    "python.analysis.typeEvaluation.strictParameterNoneValue": true,
    "python.analysis.typeEvaluation.strictSetInference": true,
    "python.analysis.useLibraryCodeForTypes": true,
    "python.defaultInterpreterPath": "C:\\Python314\\python.exe",
    "python.terminal.activateEnvironment": true,
    "python.terminal.shellIntegration.enabled": true,
    "python.testing.autoTestDiscoverOnSaveEnabled": true,
    "python.testing.pytestEnabled": true,
    "python.testing.unittestEnabled": false,
    "python.useEnvironmentsExtension": true,
    "ruff.codeAction.disableRuleComment": {
        "enable": true
    },
    "ruff.codeAction.fixViolation": {
        "enable": true
    },
    "ruff.configurationPreference": "filesystemFirst",
    "ruff.enable": true,
    "ruff.fixAll": true,
    "ruff.format.backend": "internal",
    "ruff.importStrategy": "fromEnvironment",
    "ruff.lint.enable": true,
    "ruff.nativeServer": "auto",
    "ruff.organizeImports": true,
    "ruff.trace.server": "off",
    "sonarlint.connectedMode.project": {
        "connectionId": "nick2bad4u",
        "projectKey": "Nick2bad4u_Github-Security-CodeScanning-Alerts-Skill"
    }
}
